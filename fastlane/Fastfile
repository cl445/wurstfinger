default_platform(:ios)

# Single CI predicate — GitHub Actions sets CI="true"; a bare truthy check
# would also fire on CI="false" or CI="".
def ci?
  ENV["CI"] == "true"
end

platform :ios do
  # Shared context for both lanes: validated environment plus an ASC API key.
  private_lane :asc_context do
    app_id = ENV.fetch("APP_IDENTIFIER", "de.akator.wurstfinger")
    team_id = ENV.fetch("APPLE_TEAM_ID")

    UI.user_error!("APPLE_TEAM_ID is required but not set") if team_id.nil? || team_id.empty?

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: Base64.decode64(ENV.fetch("ASC_KEY_P8_BASE64")),
      duration: 1200,
      in_house: false
    )

    { app_id: app_id, api_key: api_key }
  end

  # Sets the build number, signs both targets via match, and builds the
  # app-store ipa. Shared verbatim between the beta and release lanes so
  # signing or build fixes cannot drift between them.
  private_lane :build_signed_ipa do |options|
    app_id = options[:app_id]

    increment_build_number(
      xcodeproj: "Wurstfinger.xcodeproj",
      build_number: options[:build_number]
    )

    # Set export compliance to skip waiting
    set_info_plist_value(
      path: "wurstfingerKeyboard/Info.plist",
      key: "ITSAppUsesNonExemptEncryption",
      value: false
    )

    # Create temporary keychain for CI
    if ci?
      create_keychain(
        name: "fastlane_tmp_keychain",
        password: "temp_password_123",
        default_keychain: true,
        unlock: true,
        timeout: 3600,
        lock_when_sleeps: false
      )
    end

    match(
      type: "appstore",
      readonly: ci?,
      app_identifier: [app_id, "#{app_id}.keyboard"],
      keychain_name: ci? ? "fastlane_tmp_keychain" : "login.keychain",
      keychain_password: ci? ? "temp_password_123" : nil
    )

    # Update signing for main app target
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Wurstfinger.xcodeproj",
      targets: ["WurstfingerApp"],
      bundle_identifier: app_id,
      profile_name: "match AppStore #{app_id}",
      code_sign_identity: "iPhone Distribution"
    )

    # Update signing for keyboard extension target
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Wurstfinger.xcodeproj",
      targets: ["Wurstfinger"],
      bundle_identifier: "#{app_id}.keyboard",
      profile_name: "match AppStore #{app_id}.keyboard",
      code_sign_identity: "iPhone Distribution"
    )

    build_app(
      scheme: "Wurstfinger",
      project: "Wurstfinger.xcodeproj",
      export_method: "app-store",
      include_symbols: true,
      include_bitcode: false,
      xcargs: ci? ? "OTHER_CODE_SIGN_FLAGS='--keychain fastlane_tmp_keychain'" : nil
    )
  end

  private_lane :cleanup_ci_keychain do
    next unless ci?

    # Only delete when the keychain actually exists — the lane may fail
    # before create_keychain ran, and delete_keychain raises otherwise.
    keychain = "fastlane_tmp_keychain"
    exists = ["#{keychain}-db", keychain].any? do |name|
      File.exist?(File.expand_path("~/Library/Keychains/#{name}"))
    end
    delete_keychain(name: keychain) if exists
  end

  # Runs after any lane failure. Without this, a failed match/build/upload
  # leaves fastlane_tmp_keychain in place *and* set as the default keychain
  # on the runner. Guarded so cleanup problems never mask the original error.
  error do |_lane, _exception|
    begin
      cleanup_ci_keychain
    rescue => cleanup_error
      UI.important("CI keychain cleanup failed: #{cleanup_error.message}")
    end
  end

  desc "Build & upload to TestFlight on develop merges"
  lane :beta do
    ctx = asc_context

    # Get latest build number from TestFlight and increment
    latest_build = latest_testflight_build_number(
      api_key: ctx[:api_key],
      app_identifier: ctx[:app_id]
    )

    build_signed_ipa(app_id: ctx[:app_id], build_number: latest_build + 1)

    # The upload itself must fail the lane — a blanket rescue here once
    # masked App Store Connect rejecting every nightly binary while the
    # workflow stayed green.
    upload_to_testflight(
      api_key: ctx[:api_key],
      uses_non_exempt_encryption: false,
      changelog: ENV.fetch("CHANGELOG", "Automated build from develop.")
    )

    # External distribution and beta review submission are flaky on Apple's
    # side; the build is already uploaded, so tolerate failures here.
    begin
      upload_to_testflight(
        api_key: ctx[:api_key],
        distribute_only: true,
        build_number: lane_context[SharedValues::BUILD_NUMBER],
        groups: ["Internal", "Public Beta"],
        distribute_external: true,
        submit_beta_review: true,
        beta_app_review_info: {
          contact_email: ENV.fetch("BETA_CONTACT_EMAIL", "info@akator.de"),
          contact_first_name: ENV.fetch("BETA_CONTACT_FIRST_NAME", "Developer"),
          contact_last_name: ENV.fetch("BETA_CONTACT_LAST_NAME", "Akator"),
          contact_phone: ENV.fetch("BETA_CONTACT_PHONE", "+49 000 000000"),
          demo_account_required: false,
          notes: "MessagEase-inspired keyboard extension for iOS. Enable in Settings > General > Keyboard > Keyboards > Add New Keyboard."
        }
      )
    rescue => e
      UI.important "Beta distribution/review submission failed (build itself is uploaded): #{e.message}"
    end

    cleanup_ci_keychain
  end

  desc "Submit to App Store for review"
  lane :release do
    ctx = asc_context

    # Get latest build number from App Store and increment
    latest_build = app_store_build_number(
      api_key: ctx[:api_key],
      app_identifier: ctx[:app_id],
      live: false
    )

    build_signed_ipa(app_id: ctx[:app_id], build_number: latest_build + 1)

    # Read version from Xcode project so deliver creates the correct App Store version
    version = get_version_number(
      xcodeproj: "Wurstfinger.xcodeproj",
      target: "WurstfingerApp"
    )

    # No `build_number:` here — that option tells deliver to select an
    # already-uploaded build and silently skips uploading the freshly built
    # ipa. Without it, deliver uploads the ipa from the lane context itself.
    upload_to_app_store(
      api_key: ctx[:api_key],
      app_version: version,
      skip_metadata: false,
      skip_screenshots: false,
      screenshots_path: "./fastlane/screenshots",
      overwrite_screenshots: true,
      force: true,
      submit_for_review: false,
      precheck_include_in_app_purchases: false,
      app_review_information: {
        first_name: ENV.fetch("REVIEW_CONTACT_FIRST_NAME", ""),
        last_name: ENV.fetch("REVIEW_CONTACT_LAST_NAME", ""),
        email_address: ENV.fetch("REVIEW_CONTACT_EMAIL", ""),
        phone_number: ENV.fetch("REVIEW_CONTACT_PHONE", ""),
        demo_user: "",
        demo_password: "",
        notes: File.read("metadata/review_information/notes.txt")
      }
    )

    cleanup_ci_keychain
  end
end
