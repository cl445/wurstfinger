    "Types the large character in the center of a key.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schreibt das große Zeichen in der Mitte einer Taste."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Saisit le grand caractère au centre de la touche."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Escribe el carácter grande del centro de la tecla."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Digita il carattere grande al centro del tasto."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вводит крупный символ в центре клавиши."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wpisuje duży znak ze środka klawisza."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Skriver det stora tecknet i mitten av tangenten."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kirjoittaa näppäimen keskellä olevan ison merkin."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Upisuje veliki znak u sredini tipke."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "מקליד את התו הגדול שבמרכז המקש."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Gõ ký tự lớn ở giữa phím."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Nagta-type ng malaking character sa gitna ng key."
          }
        }
      }
    },
    "Types the small character shown in that direction on the key.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schreibt das kleine Zeichen, das in dieser Richtung auf der Taste steht."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Saisit le petit caractère affiché dans cette direction sur la touche."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Escribe el carácter pequeño que aparece en esa dirección en la tecla."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Digita il carattere piccolo mostrato in quella direzione sul tasto."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вводит маленький символ, показанный в этом направлении на клавише."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wpisuje mały znak widoczny w tym kierunku na klawiszu."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Skriver det lilla tecknet som visas i den riktningen på tangenten."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kirjoittaa pienen merkin, joka näkyy näppäimessä siinä suunnassa."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Upisuje mali znak prikazan u tom smjeru na tipki."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "מקליד את התו הקטן המוצג בכיוון זה על המקש."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Gõ ký tự nhỏ hiển thị theo hướng đó trên phím."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Nagta-type ng maliit na character na nakikita sa direksyong iyon sa key."
          }
        }
      }
    },
    "Swipe away and back without lifting your finger to get the key's alternate character.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wische weg und zurück, ohne den Finger abzuheben, um das Alternativzeichen der Taste zu erhalten."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Balayez vers l'extérieur puis revenez sans lever le doigt pour obtenir le caractère alternatif de la touche."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desliza hacia fuera y de vuelta sin levantar el dedo para obtener el carácter alternativo de la tecla."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scorri via e torna indietro senza sollevare il dito per ottenere il carattere alternativo del tasto."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Проведите пальцем в сторону и обратно, не отрывая его, чтобы получить альтернативный символ клавиши."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przesuń palcem w bok i z powrotem bez odrywania go, aby uzyskać alternatywny znak klawisza."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Svep bort och tillbaka utan att lyfta fingret för att få tangentens alternativa tecken."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyyhkäise poispäin ja takaisin nostamatta sormea saadaksesi näppäimen vaihtoehtoisen merkin."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Povuci prstom van i natrag bez podizanja prsta da dobiješ alternativni znak tipke."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "החליקו החוצה ובחזרה בלי להרים את האצבע כדי לקבל את התו החלופי של המקש."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Vuốt ra rồi quay lại mà không nhấc ngón tay để nhận ký tự thay thế của phím."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Mag-swipe palayo at pabalik nang hindi inaangat ang daliri para makuha ang alternatibong character ng key."
          }
        }
      }
    },
    "Draw a small circle on a letter key to type it as an uppercase letter.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zeichne einen kleinen Kreis auf einer Buchstabentaste, um den Buchstaben groß zu schreiben."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dessinez un petit cercle sur une touche de lettre pour la saisir en majuscule."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Dibuja un pequeño círculo sobre una tecla de letra para escribirla en mayúscula."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Disegna un piccolo cerchio su un tasto lettera per digitarla in maiuscolo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нарисуйте маленький круг на клавише с буквой, чтобы ввести её заглавной."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Narysuj małe kółko na klawiszu litery, aby wpisać ją jako wielką literę."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Rita en liten cirkel på en bokstavstangent för att skriva den som versal."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Piirrä pieni ympyrä kirjainnäppäimelle kirjoittaaksesi kirjaimen isolla."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nacrtaj mali krug na tipki slova da ga upišeš kao veliko slovo."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "ציירו עיגול קטן על מקש אות כדי להקליד אותה כאות גדולה."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Vẽ một vòng tròn nhỏ trên phím chữ để gõ chữ đó ở dạng in hoa."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Gumuhit ng maliit na bilog sa isang letter key para i-type ito bilang malaking titik."
          }
        }
      }
    },
    "Hold and drag the space key to move the cursor through your text.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Halte die Leertaste und ziehe sie, um den Cursor durch deinen Text zu bewegen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Maintenez et faites glisser la touche espace pour déplacer le curseur dans votre texte."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén pulsada y arrastra la tecla de espacio para mover el cursor por el texto."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tieni premuta e trascina la barra spaziatrice per muovere il cursore nel testo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Удерживайте и перетаскивайте пробел, чтобы перемещать курсор по тексту."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przytrzymaj i przeciągnij spację, aby przesuwać kursor po tekście."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Håll och dra mellanslagstangenten för att flytta markören genom texten."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pidä välilyöntinäppäintä painettuna ja vedä siirtääksesi kohdistinta tekstissä."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Drži i povlači razmaknicu za pomicanje pokazivača kroz tekst."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "החזיקו וגררו את מקש הרווח כדי להזיז את הסמן בטקסט."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Giữ và kéo phím cách để di chuyển con trỏ trong văn bản."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindutin nang matagal at i-drag ang space key para igalaw ang cursor sa iyong text."
          }
        }
      }
    },
    "Hold and drag the delete key to keep deleting — the further you drag, the more it removes.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Halte die Löschtaste und ziehe sie, um fortlaufend zu löschen — je weiter du ziehst, desto mehr wird entfernt."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Maintenez et faites glisser la touche d'effacement pour continuer à effacer — plus vous glissez loin, plus elle supprime."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén pulsada y arrastra la tecla de borrado para seguir borrando: cuanto más arrastres, más se elimina."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tieni premuto e trascina il tasto elimina per continuare a cancellare: più trascini, più viene rimosso."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Удерживайте и перетаскивайте клавишу удаления, чтобы продолжать удалять — чем дальше тянете, тем больше удаляется."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przytrzymaj i przeciągnij klawisz kasowania, aby usuwać dalej — im dalej przeciągniesz, tym więcej znika."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Håll och dra raderingstangenten för att fortsätta radera — ju längre du drar, desto mer tas bort."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pidä poistonäppäintä painettuna ja vedä jatkaaksesi poistamista — mitä pidemmälle vedät, sitä enemmän poistuu."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Drži i povlači tipku za brisanje za neprekidno brisanje — što dalje povlačiš, više se briše."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "החזיקו וגררו את מקש המחיקה כדי להמשיך למחוק — ככל שגוררים רחוק יותר, נמחק יותר."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Giữ và kéo phím xóa để tiếp tục xóa — kéo càng xa, xóa càng nhiều."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Pindutin nang matagal at i-drag ang delete key para tuloy-tuloy na magbura — habang mas malayo ang drag, mas marami ang nabubura."
          }
        }
      }
    },
    "On the 123 key: swipe up to copy, up-right to cut, down to paste.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Auf der 123-Taste: nach oben wischen zum Kopieren, nach oben rechts zum Ausschneiden, nach unten zum Einfügen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sur la touche 123 : balayez vers le haut pour copier, en haut à droite pour couper, vers le bas pour coller."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "En la tecla 123: desliza hacia arriba para copiar, arriba a la derecha para cortar y hacia abajo para pegar."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sul tasto 123: scorri in alto per copiare, in alto a destra per tagliare, in basso per incollare."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "На клавише 123: смахните вверх — копировать, вверх-вправо — вырезать, вниз — вставить."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Na klawiszu 123: przesuń w górę, aby skopiować, w górę w prawo, aby wyciąć, w dół, aby wkleić."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "På 123-tangenten: svep uppåt för att kopiera, uppåt höger för att klippa ut, nedåt för att klistra in."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "123-näppäimellä: pyyhkäise ylös kopioidaksesi, yläoikealle leikataksesi, alas liittääksesi."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Na tipki 123: povuci gore za kopiranje, gore-desno za izrezivanje, dolje za lijepljenje."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "על מקש 123: החליקו למעלה להעתקה, למעלה-ימינה לגזירה, למטה להדבקה."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Trên phím 123: vuốt lên để sao chép, lên-phải để cắt, xuống để dán."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Sa 123 key: mag-swipe pataas para kumopya, pataas-pakanan para gumupit, pababa para mag-paste."
          }
        }
      }
    },
    "Swipe left to switch to the next system keyboard, swipe right to change the language, swipe down to hide the keyboard.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wische nach links, um zur nächsten Systemtastatur zu wechseln, nach rechts, um die Sprache zu ändern, und nach unten, um die Tastatur auszublenden."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Balayez vers la gauche pour passer au clavier système suivant, vers la droite pour changer de langue, vers le bas pour masquer le clavier."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desliza a la izquierda para cambiar al siguiente teclado del sistema, a la derecha para cambiar de idioma y hacia abajo para ocultar el teclado."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scorri a sinistra per passare alla tastiera di sistema successiva, a destra per cambiare lingua, in basso per nascondere la tastiera."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Смахните влево, чтобы перейти к следующей системной клавиатуре, вправо — чтобы сменить язык, вниз — чтобы скрыть клавиатуру."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przesuń w lewo, aby przełączyć na następną klawiaturę systemową, w prawo, aby zmienić język, w dół, aby ukryć klawiaturę."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Svep åt vänster för att byta till nästa systemtangentbord, åt höger för att byta språk, nedåt för att dölja tangentbordet."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pyyhkäise vasemmalle vaihtaaksesi seuraavaan järjestelmänäppäimistöön, oikealle vaihtaaksesi kieltä ja alas piilottaaksesi näppäimistön."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Povuci ulijevo za prelazak na sljedeću sistemsku tipkovnicu, udesno za promjenu jezika, prema dolje za skrivanje tipkovnice."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "החליקו שמאלה כדי לעבור למקלדת המערכת הבאה, ימינה כדי להחליף שפה ולמטה כדי להסתיר את המקלדת."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Vuốt sang trái để chuyển sang bàn phím hệ thống tiếp theo, sang phải để đổi ngôn ngữ, xuống dưới để ẩn bàn phím."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Mag-swipe pakaliwa para lumipat sa susunod na system keyboard, pakanan para magpalit ng wika, pababa para itago ang keyboard."
          }
        }
      }
    },
    "Try all gestures safely in the Test tab or the settings preview.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Probiere alle Gesten gefahrlos im Test-Tab oder in der Vorschau der Einstellungen aus."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Essayez tous les gestes en toute sécurité dans l'onglet Test ou dans l'aperçu des réglages."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Prueba todos los gestos sin riesgo en la pestaña Prueba o en la vista previa de los ajustes."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Prova tutti i gesti in sicurezza nella scheda Test o nell'anteprima delle impostazioni."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Безопасно попробуйте все жесты на вкладке «Тест» или в предпросмотре настроек."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wypróbuj wszystkie gesty bezpiecznie na karcie Test lub w podglądzie ustawień."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Prova alla gester riskfritt på fliken Test eller i inställningarnas förhandsvisning."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kokeile kaikkia eleitä turvallisesti Testi-välilehdellä tai asetusten esikatselussa."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Isprobaj sve geste bez brige na kartici Test ili u pregledu postavki."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "נסו את כל המחוות בבטחה בלשונית הבדיקה או בתצוגה המקדימה של ההגדרות."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thử tất cả cử chỉ một cách an toàn trong thẻ Kiểm tra hoặc bản xem trước trong cài đặt."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Subukan ang lahat ng galaw nang ligtas sa Test tab o sa preview ng mga setting."
          }
        }
      }
    }
  },
  "version": "1.0"
}
